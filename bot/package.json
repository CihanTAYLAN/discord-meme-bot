{
  "name": "bot",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "lint": "biome check src",
    "register:commands": "tsx src/register-commands.ts",
    "start": "node dist/index.js",
    "test": "vitest run src",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.1",
    "discord.js": "^14.25.1",
    "ffmpeg-static": "^5.3.0",
    "opusscript": "0.1.1",
    "prism-media": "^1.3.5"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
