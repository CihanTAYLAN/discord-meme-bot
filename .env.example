NODE_ENV=development
LOG_LEVEL=info

DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_API_BASE_URL=http://localhost:4000
DISCORD_COMMANDS_GLOBAL=false
DISCORD_DAVE_ENCRYPTION=true
DISCORD_ENABLE_TEXT_COMMANDS=false

API_HOST=0.0.0.0
API_PORT=4000
API_PUBLIC_BASE_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:5173

CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION_NAME=meme_sounds
CHROMA_RESULTS_LIMIT=5
SIMILARITY_THRESHOLD=0.58

EMBEDDING_MODEL=Xenova/paraphrase-multilingual-MiniLM-L12-v2
TRANSFORMERS_CACHE_DIR=./data/transformers-cache

WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=
WHISPER_BEAM_SIZE=1

SEGMENT_SILENCE_MS=1500
SEGMENT_MIN_MS=3000
SEGMENT_MAX_MS=20000
SEGMENT_MAX_GRACE_MS=2500
SEMANTIC_MERGE_WINDOW_MS=2500
SEMANTIC_PENDING_TAIL_SILENCE_MS=600

DASHBOARD_API_BASE_URL=http://localhost:4000
DASHBOARD_APP_ENV=development
