{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "api/src/**/*.ts",
      "bot/src/**/*.ts",
      "dashboard/src/**/*.{ts,tsx}",
      "dashboard/scripts/*.js"
    ]
  }
}
